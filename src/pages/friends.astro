---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { brand } from "@/data/site";
import { friends, siteProfile } from "@/data/friends";
import { withBase } from "@/utils/url";

const issueTitle = encodeURIComponent(`友链交换 - ${brand.name}`);
const issueBody = encodeURIComponent(
  [
    "你好，我想交换友情链接。",
    "",
    "站点名称：",
    "站点地址：",
    "一句描述：",
    "头像地址："
  ].join("\n")
);
const issueHref = `https://github.com/longwudf/shiyuboke/issues/new?title=${issueTitle}&body=${issueBody}`;
---

<BaseLayout title={`友情链接 | ${brand.name}`} description={`${brand.name} 的朋友站点和技术博客链接。`}>
  <section class="content-grid py-12">
    <div class="mb-10 grid gap-6 lg:grid-cols-[minmax(0,1fr)_320px] lg:items-end">
      <div>
        <p class="text-sm font-semibold text-coral">Friends</p>
        <h1 class="mt-2 text-4xl font-black text-slate-950 dark:text-white">友情链接</h1>
        <p class="mt-4 max-w-2xl text-lg leading-8 text-slate-600 dark:text-slate-300">
          收集认真写作、长期维护、内容气质相近的个人站点。
        </p>
      </div>
      <aside class="surface rounded-lg p-5">
        <p class="text-sm font-semibold text-teal-700 dark:text-teal-300">本站信息</p>
        <div class="mt-4 flex items-start gap-4">
          <img class="h-12 w-12 rounded-lg border border-slate-200 bg-white p-2 dark:border-slate-800 dark:bg-slate-900" src={withBase("/favicon.svg")} alt={brand.name} loading="lazy" />
          <div>
            <h2 class="font-bold text-slate-950 dark:text-white">{siteProfile.name}</h2>
            <p class="mt-1 text-sm leading-6 text-slate-600 dark:text-slate-300">{siteProfile.description}</p>
          </div>
        </div>
      </aside>
    </div>

    <div class="grid gap-5 md:grid-cols-2">
      {friends.map((friend) => (
        <a
          class="surface group flex gap-4 rounded-lg p-5 transition hover:-translate-y-0.5 hover:border-teal-300"
          href={friend.href}
          target="_blank"
          rel="noreferrer"
        >
          <div class="flex h-14 w-14 shrink-0 items-center justify-center overflow-hidden rounded-lg border border-slate-200 bg-white text-lg font-black text-teal-700 dark:border-slate-800 dark:bg-slate-900 dark:text-teal-200">
            {friend.avatar ? (
              <img class="h-full w-full object-cover" src={friend.avatar} alt={friend.name} loading="lazy" />
            ) : (
              friend.name.slice(0, 2)
            )}
          </div>
          <div class="min-w-0">
            <h2 class="font-bold text-slate-950 group-hover:text-teal-700 dark:text-white dark:group-hover:text-teal-200">{friend.name}</h2>
            <p class="mt-2 text-sm leading-6 text-slate-600 dark:text-slate-300">{friend.description}</p>
            {friend.tags && friend.tags.length > 0 && (
              <div class="mt-3 flex flex-wrap gap-2">
                {friend.tags.map((tag) => <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600 dark:bg-slate-800 dark:text-slate-300">{tag}</span>)}
              </div>
            )}
          </div>
        </a>
      ))}
    </div>

    <section class="surface mt-6 rounded-lg p-6">
      <h2 class="text-xl font-bold text-slate-950 dark:text-white">交换友链</h2>
      <p class="mt-3 leading-7 text-slate-600 dark:text-slate-300">
        如果你也在长期维护个人博客，欢迎通过 GitHub Issue 留下站点信息。
      </p>
      <a class="mt-5 inline-flex rounded-full bg-slate-950 px-5 py-3 text-sm font-semibold text-white transition hover:bg-teal-700 dark:bg-white dark:text-slate-950 dark:hover:bg-teal-100" href={issueHref} target="_blank" rel="noreferrer">
        提交友链信息
      </a>
    </section>
  </section>
</BaseLayout>
