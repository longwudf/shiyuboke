---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { withBase } from "@/utils/url";

const searchIndexUrl = withBase("/search-index.json");
---

<BaseLayout title="搜索 | Longwu.dev" description="搜索已发布的技术文章。">
  <section class="content-grid py-12">
    <div class="mx-auto max-w-4xl">
      <div class="mb-8">
        <h1 class="text-4xl font-black text-slate-950 dark:text-white">搜索文章</h1>
        <p class="mt-4 text-lg leading-8 text-slate-600 dark:text-slate-300">搜索标题、描述、标签和正文内容。索引在构建时生成，查询完全在浏览器本地完成。</p>
      </div>

      <div class="surface rounded-lg p-4 sm:p-5">
        <label class="block">
          <span class="mb-2 block text-sm font-semibold text-slate-700 dark:text-slate-200">关键词</span>
          <div class="relative">
            <svg class="pointer-events-none absolute left-4 top-1/2 h-5 w-5 -translate-y-1/2 text-slate-400" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="m21 21-4.3-4.3M10.8 18a7.2 7.2 0 1 1 0-14.4 7.2 7.2 0 0 1 0 14.4Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
            </svg>
            <input
              id="search-input"
              class="h-12 w-full rounded-lg border border-slate-300 bg-white pl-11 pr-4 text-base text-slate-950 outline-none transition placeholder:text-slate-400 focus:border-teal-500 focus:ring-4 focus:ring-teal-100 dark:border-slate-700 dark:bg-slate-950 dark:text-white dark:focus:border-teal-400 dark:focus:ring-teal-950"
              type="search"
              placeholder="例如 Astro、TypeScript、GitHub Pages"
              autocomplete="off"
              data-index-url={searchIndexUrl}
            />
          </div>
        </label>

        <div class="mt-4 flex flex-wrap items-center justify-between gap-3 text-sm text-slate-500 dark:text-slate-400">
          <p id="search-count">正在加载搜索索引...</p>
          <a class="font-semibold text-teal-700 hover:text-teal-900 dark:text-teal-300 dark:hover:text-teal-100" href={withBase("/archive")}>查看归档</a>
        </div>
      </div>

      <div id="search-results" class="mt-8 grid gap-4" aria-live="polite"></div>
    </div>
  </section>
</BaseLayout>

<script>
  type SearchItem = {
    title: string;
    description: string;
    category: string;
    tags: string[];
    date: string;
    readingTime: string;
    url: string;
    searchable: string;
  };

  const input = document.getElementById("search-input") as HTMLInputElement | null;
  const results = document.getElementById("search-results");
  const count = document.getElementById("search-count");
  let items: SearchItem[] = [];

  const escapeHtml = (value: string) =>
    value.replace(/[&<>"']/g, (char) => {
      const entities: Record<string, string> = {
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#39;"
      };
      return entities[char];
    });

  const normalizeQuery = (value: string) =>
    value
      .trim()
      .toLowerCase()
      .split(/\s+/u)
      .filter(Boolean);

  const render = (query = "") => {
    const keywords = query
      ? normalizeQuery(query)
      : [];
    const matched = keywords.length
      ? items.filter((item) => keywords.every((keyword) => item.searchable.includes(keyword)))
      : items;

    if (count) {
      count.textContent = keywords.length ? `找到 ${matched.length} 篇相关文章` : `共 ${items.length} 篇文章`;
    }

    if (!results) return;

    if (matched.length === 0) {
      results.innerHTML = `<div class="surface rounded-lg p-6 text-slate-600 dark:text-slate-300">没有找到匹配文章，可以换一个关键词试试。</div>`;
      return;
    }

    results.innerHTML = matched
      .map(
        (item) => `
          <article class="surface rounded-lg p-5 transition hover:border-teal-300">
            <div class="mb-3 flex flex-wrap items-center gap-2 text-sm text-slate-500 dark:text-slate-400">
              <span class="rounded-full bg-slate-100 px-3 py-1 font-medium text-slate-700 dark:bg-slate-800 dark:text-slate-200">${escapeHtml(item.category)}</span>
              <span>${escapeHtml(item.date)}</span>
              <span>${escapeHtml(item.readingTime)}</span>
            </div>
            <a class="group block" href="${item.url}">
              <h2 class="text-xl font-bold leading-tight text-slate-950 group-hover:text-teal-700 dark:text-white dark:group-hover:text-teal-200">${escapeHtml(item.title)}</h2>
              <p class="mt-3 text-slate-600 dark:text-slate-300">${escapeHtml(item.description)}</p>
            </a>
            <div class="mt-4 flex flex-wrap gap-2">
              ${item.tags.map((tag) => `<span class="tag-pill">#${escapeHtml(tag)}</span>`).join("")}
            </div>
          </article>
        `
      )
      .join("");
  };

  const showError = () => {
    if (count) count.textContent = "搜索索引加载失败";
    if (results) {
      results.innerHTML = `<div class="surface rounded-lg p-6 text-slate-600 dark:text-slate-300">暂时无法加载搜索索引，请稍后刷新页面。</div>`;
    }
  };

  const loadIndex = async () => {
    if (!input) return;

    try {
      const response = await fetch(input.dataset.indexUrl ?? "/search-index.json");
      if (!response.ok) throw new Error("Failed to load search index");
      items = (await response.json()) as SearchItem[];
      const initialQuery = new URLSearchParams(window.location.search).get("q") ?? "";
      input.value = initialQuery;
      render(input.value);
    } catch {
      showError();
    }
  };

  input?.addEventListener("input", () => {
    render(input.value);
    const url = new URL(window.location.href);
    if (input.value.trim()) {
      url.searchParams.set("q", input.value.trim());
    } else {
      url.searchParams.delete("q");
    }
    window.history.replaceState({}, "", url);
  });
  loadIndex();
</script>
