---
import { getCollection } from "astro:content";
import { about } from "@/data/about";
import { brand } from "@/data/site";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { filterPublished, formatDate, getReadingStats, sortPosts } from "@/utils/posts";

const posts = sortPosts(filterPublished(await getCollection("blog")));
const tagCount = new Set(posts.flatMap((post) => post.data.tags)).size;
const totalWords = posts.reduce((sum, post) => sum + getReadingStats(post.body).words, 0);
const latestUpdate = posts.reduce<Date | undefined>((latest, post) => {
  const date = post.data.updatedDate ?? post.data.date;
  if (!latest || date.valueOf() > latest.valueOf()) return date;
  return latest;
}, undefined);
const numberFormatter = new Intl.NumberFormat("zh-CN");
---

<BaseLayout title={`${about.title} | ${brand.name}`} description={about.description}>
  <section class="content-grid py-12">
    <div class="mx-auto max-w-3xl">
      <h1 class="text-4xl font-black text-slate-950 dark:text-white">{about.title}</h1>
      <div class="prose-blog mt-8">
        {about.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
      </div>
      <dl class="mt-10 grid gap-4 sm:grid-cols-4">
        <div class="surface rounded-lg p-4">
          <dt class="text-xs text-slate-500 dark:text-slate-400">文章</dt>
          <dd class="mt-1 text-2xl font-black text-slate-950 dark:text-white">{posts.length}</dd>
        </div>
        <div class="surface rounded-lg p-4">
          <dt class="text-xs text-slate-500 dark:text-slate-400">标签</dt>
          <dd class="mt-1 text-2xl font-black text-slate-950 dark:text-white">{tagCount}</dd>
        </div>
        <div class="surface rounded-lg p-4">
          <dt class="text-xs text-slate-500 dark:text-slate-400">总字数</dt>
          <dd class="mt-1 text-2xl font-black text-slate-950 dark:text-white">{numberFormatter.format(totalWords)}</dd>
        </div>
        <div class="surface rounded-lg p-4">
          <dt class="text-xs text-slate-500 dark:text-slate-400">最近更新</dt>
          <dd class="mt-1 text-sm font-black text-slate-950 dark:text-white">{latestUpdate ? formatDate(latestUpdate) : "暂无"}</dd>
        </div>
      </dl>
    </div>
  </section>
</BaseLayout>
