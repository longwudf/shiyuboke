---
import { brand } from "@/data/site";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { withBase } from "@/utils/url";
---

<BaseLayout title={`页面未找到 | ${brand.name}`} description="请求的页面不存在。">
  <section class="content-grid flex min-h-[60vh] items-center py-12">
    <div class="max-w-xl">
      <p class="text-sm font-semibold text-teal-700 dark:text-teal-300">404</p>
      <h1 class="mt-3 text-4xl font-black text-slate-950 dark:text-white">页面未找到</h1>
      <p class="mt-4 text-lg leading-8 text-slate-600 dark:text-slate-300">这个地址没有对应的静态页面，可能是链接已移动或输入有误。</p>
      <a class="mt-8 inline-flex rounded-full bg-slate-950 px-5 py-3 text-sm font-semibold text-white hover:bg-teal-700 dark:bg-white dark:text-slate-950" href={withBase("/")}>回到首页</a>
    </div>
  </section>
</BaseLayout>
