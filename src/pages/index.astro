---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostCard from "@/components/PostCard.astro";
import { filterPublished, sortPosts } from "@/utils/posts";
import { withBase } from "@/utils/url";

const posts = sortPosts(filterPublished(await getCollection("blog")));
const latestPosts = posts.slice(0, 3);
const featuredPosts = posts.filter((post) => post.data.featured).slice(0, 2);
const tagCount = new Set(posts.flatMap((post) => post.data.tags)).size;

const socialLinks = [
  { href: "https://github.com/longwudf", label: "GitHub", external: true },
  { href: "mailto:hello@longwu.dev", label: "Email" },
  { href: withBase("/rss.xml"), label: "RSS" }
];
---

<BaseLayout title="Longwu.dev | 技术博客" description="记录 Astro、TypeScript、前端工程化和静态站点部署实践。">
  <section class="border-b border-slate-200/80 dark:border-slate-800">
    <div class="content-grid py-14 sm:py-20">
      <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_360px] lg:items-end">
        <div>
          <div class="mb-6 flex flex-wrap items-center gap-3">
            <span class="inline-flex h-12 w-12 items-center justify-center rounded-lg bg-slate-950 text-lg font-black text-white dark:bg-white dark:text-slate-950">LW</span>
            <div>
              <p class="text-sm font-semibold uppercase tracking-[0.18em] text-teal-700 dark:text-teal-300">Longwu.dev</p>
              <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Frontend Engineer · Static-first Writer</p>
            </div>
          </div>
          <h1 class="max-w-4xl text-4xl font-black leading-tight text-slate-950 sm:text-6xl dark:text-white">
            你好，我是 Longwu。这里记录前端工程、静态站点和长期写作。
          </h1>
          <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-600 dark:text-slate-300">
            我关注类型安全、构建体验、内容系统和稳定部署，把日常工程里的判断沉淀成可复用的技术笔记。
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a class="rounded-full bg-slate-950 px-5 py-3 text-sm font-semibold text-white transition hover:bg-teal-700 dark:bg-white dark:text-slate-950 dark:hover:bg-teal-100" href={withBase("/blog")}>阅读文章</a>
            <a class="rounded-full border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-800 transition hover:border-teal-500 hover:text-teal-700 dark:border-slate-700 dark:text-slate-100 dark:hover:border-teal-300 dark:hover:text-teal-200" href={withBase("/projects")}>查看项目</a>
            <a class="rounded-full border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-800 transition hover:border-coral hover:text-coral dark:border-slate-700 dark:text-slate-100" href={withBase("/search")}>搜索笔记</a>
          </div>
          <div class="mt-8 flex flex-wrap items-center gap-3 text-sm">
            {socialLinks.map((link) => (
              <a
                class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white px-4 py-2 font-semibold text-slate-700 transition hover:border-teal-400 hover:text-teal-700 dark:border-slate-800 dark:bg-slate-900 dark:text-slate-200 dark:hover:border-teal-500 dark:hover:text-teal-200"
                href={link.href}
                target={link.external ? "_blank" : undefined}
                rel={link.external ? "noreferrer" : undefined}
              >
                {link.label}
              </a>
            ))}
          </div>
        </div>

        <aside class="surface rounded-lg p-6">
          <p class="text-sm font-semibold text-coral">Now</p>
          <h2 class="mt-2 text-2xl font-black text-slate-950 dark:text-white">当前关注</h2>
          <p class="mt-3 leading-7 text-slate-600 dark:text-slate-300">
            静态优先、类型驱动、可维护的内容结构，以及能在 GitHub Pages 上安静运行很久的个人站点。
          </p>
          <dl class="mt-6 grid grid-cols-3 gap-3 text-center">
            <div class="rounded-lg border border-slate-200 p-3 dark:border-slate-800">
              <dt class="text-xs text-slate-500 dark:text-slate-400">文章</dt>
              <dd class="mt-1 text-2xl font-black text-slate-950 dark:text-white">{posts.length}</dd>
            </div>
            <div class="rounded-lg border border-slate-200 p-3 dark:border-slate-800">
              <dt class="text-xs text-slate-500 dark:text-slate-400">标签</dt>
              <dd class="mt-1 text-2xl font-black text-slate-950 dark:text-white">{tagCount}</dd>
            </div>
            <div class="rounded-lg border border-slate-200 p-3 dark:border-slate-800">
              <dt class="text-xs text-slate-500 dark:text-slate-400">精选</dt>
              <dd class="mt-1 text-2xl font-black text-slate-950 dark:text-white">{featuredPosts.length}</dd>
            </div>
          </dl>
        </aside>
      </div>
    </div>
  </section>

  <section class="content-grid py-12">
    <div class="mb-6 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-sm font-semibold text-teal-700 dark:text-teal-300">Featured</p>
        <h2 class="mt-1 text-3xl font-black text-slate-950 dark:text-white">精选文章</h2>
      </div>
      <a class="text-sm font-semibold text-teal-700 hover:text-teal-900 dark:text-teal-300 dark:hover:text-teal-100" href={withBase("/archive")}>查看归档</a>
    </div>
    <div class="grid gap-5 md:grid-cols-2">
      {featuredPosts.map((post) => <PostCard post={post} featured />)}
    </div>
  </section>

  <section class="content-grid py-12">
    <div class="mb-6 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-sm font-semibold text-teal-700 dark:text-teal-300">Latest</p>
        <h2 class="mt-1 text-3xl font-black text-slate-950 dark:text-white">最新文章</h2>
      </div>
      <a class="text-sm font-semibold text-teal-700 hover:text-teal-900 dark:text-teal-300 dark:hover:text-teal-100" href={withBase("/blog")}>全部文章</a>
    </div>
    <div class="grid gap-5 md:grid-cols-3">
      {latestPosts.map((post) => <PostCard post={post} />)}
    </div>
  </section>

  <section class="content-grid py-12">
    <div class="grid gap-5 lg:grid-cols-[0.85fr_1.15fr] lg:items-stretch">
      <div class="surface rounded-lg p-6">
        <p class="text-sm font-semibold text-coral">Projects</p>
        <h2 class="mt-2 text-3xl font-black text-slate-950 dark:text-white">项目展示入口</h2>
        <p class="mt-4 leading-7 text-slate-600 dark:text-slate-300">
          这里会收集可公开展示的前端应用、组件实验、博客模板和工程化实践。文章记录思路，项目承载结果。
        </p>
        <a class="mt-6 inline-flex rounded-full bg-teal-700 px-5 py-3 text-sm font-semibold text-white transition hover:bg-teal-800" href={withBase("/projects")}>进入项目页</a>
      </div>
      <div class="grid gap-5 sm:grid-cols-3">
        <div class="surface rounded-lg p-5">
          <p class="text-sm font-semibold text-teal-700 dark:text-teal-300">Template</p>
          <h3 class="mt-2 font-bold text-slate-950 dark:text-white">Astro 静态博客</h3>
          <p class="mt-3 text-sm leading-6 text-slate-600 dark:text-slate-300">内容集合、RSS、Sitemap 和 GitHub Pages 部署。</p>
        </div>
        <div class="surface rounded-lg p-5">
          <p class="text-sm font-semibold text-teal-700 dark:text-teal-300">Tooling</p>
          <h3 class="mt-2 font-bold text-slate-950 dark:text-white">TypeScript 工程化</h3>
          <p class="mt-3 text-sm leading-6 text-slate-600 dark:text-slate-300">围绕类型边界、构建检查和协作脚本整理实践。</p>
        </div>
        <div class="surface rounded-lg p-5">
          <p class="text-sm font-semibold text-teal-700 dark:text-teal-300">Deploy</p>
          <h3 class="mt-2 font-bold text-slate-950 dark:text-white">静态部署流程</h3>
          <p class="mt-3 text-sm leading-6 text-slate-600 dark:text-slate-300">把可重复构建和可回滚发布变成默认路径。</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-600 dark:text-slate-300">
          这里整理 Astro、TypeScript、构建部署和工程质量相关的实践笔记，偏向清晰、可维护、能长期托管的技术博客写作。
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a class="rounded-full bg-slate-950 px-5 py-3 text-sm font-semibold text-white transition hover:bg-teal-700 dark:bg-white dark:text-slate-950 dark:hover:bg-teal-100" href={withBase("/blog")}>阅读文章</a>
          <a class="rounded-full border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-800 transition hover:border-teal-500 hover:text-teal-700 dark:border-slate-700 dark:text-slate-100 dark:hover:border-teal-300 dark:hover:text-teal-200" href={withBase("/projects")}>查看项目</a>
        </div>
      </div>
      <div class="surface rounded-lg p-6">
        <div class="grid grid-cols-2 gap-4 text-sm">
          <div>
            <p class="text-3xl font-black text-slate-950 dark:text-white">{posts.length}</p>
            <p class="mt-1 text-slate-500 dark:text-slate-400">已发布文章</p>
          </div>
          <div>
            <p class="text-3xl font-black text-slate-950 dark:text-white">{new Set(posts.flatMap((post) => post.data.tags)).size}</p>
            <p class="mt-1 text-slate-500 dark:text-slate-400">技术标签</p>
          </div>
          <div class="col-span-2 rounded-lg bg-teal-50 p-4 dark:bg-teal-950/50">
            <p class="font-semibold text-teal-900 dark:text-teal-100">当前关注</p>
            <p class="mt-2 text-slate-600 dark:text-slate-300">静态优先、类型安全、清爽排版和稳定部署。</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="content-grid py-10">
    <div class="mb-6 flex items-end justify-between gap-4">
      <div>
        <p class="text-sm font-semibold text-teal-700 dark:text-teal-300">Latest</p>
        <h2 class="mt-1 text-2xl font-bold text-slate-950 dark:text-white">最新文章</h2>
      </div>
      <a class="text-sm font-semibold text-teal-700 hover:text-teal-900 dark:text-teal-300 dark:hover:text-teal-100" href={withBase("/blog")}>全部文章</a>
    </div>
    <div class="grid gap-5 md:grid-cols-3">
      {latestPosts.map((post) => <PostCard post={post} />)}
    </div>
  </section>

  <section class="content-grid py-10">
    <div class="mb-6">
      <p class="text-sm font-semibold text-teal-700 dark:text-teal-300">Featured</p>
      <h2 class="mt-1 text-2xl font-bold text-slate-950 dark:text-white">精选文章</h2>
    </div>
    <div class="grid gap-5 md:grid-cols-2">
      {featuredPosts.map((post) => <PostCard post={post} featured />)}
    </div>
  </section>

  <section class="content-grid py-10">
    <div class="surface flex flex-col gap-5 rounded-lg p-6 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <p class="text-sm font-semibold text-coral">Projects</p>
        <h2 class="mt-1 text-2xl font-bold text-slate-950 dark:text-white">项目展示入口</h2>
        <p class="mt-2 text-slate-600 dark:text-slate-300">收集可公开展示的前端应用、组件实验和工程模板。</p>
      </div>
      <a class="rounded-full bg-teal-700 px-5 py-3 text-sm font-semibold text-white transition hover:bg-teal-800" href={withBase("/projects")}>进入项目页</a>
    </div>
  </section>
</BaseLayout>
