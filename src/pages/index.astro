---
import { getCollection } from "astro:content";
import { brand, site } from "@/data/site";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostCard from "@/components/PostCard.astro";
import { filterPublished, formatDate, getReadingStats, sortPosts } from "@/utils/posts";
import { withBase } from "@/utils/url";

const posts = sortPosts(filterPublished(await getCollection("blog")));
const latestPosts = posts.slice(0, 3);
const featuredPosts = posts.filter((post) => post.data.featured).slice(0, 2);
const tagCount = new Set(posts.flatMap((post) => post.data.tags)).size;
const totalWords = posts.reduce((sum, post) => sum + getReadingStats(post.body).words, 0);
const latestUpdate = posts.reduce<Date | undefined>((latest, post) => {
  const date = post.data.updatedDate ?? post.data.date;
  if (!latest || date.valueOf() > latest.valueOf()) return date;
  return latest;
}, undefined);
const numberFormatter = new Intl.NumberFormat("zh-CN");
const home = site.home;
const homeActionClass = (variant?: string) =>
  variant === "primary"
    ? "rounded-full bg-slate-950 px-5 py-3 text-sm font-semibold text-white transition hover:bg-teal-700 dark:bg-white dark:text-slate-950 dark:hover:bg-teal-100"
    : "rounded-full border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-800 transition hover:border-teal-500 hover:text-teal-700 dark:border-slate-700 dark:text-slate-100 dark:hover:border-teal-300 dark:hover:text-teal-200";
const resolveLink = (href: string) => href.startsWith("http") || href.startsWith("mailto:") ? href : withBase(href);

const siteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: brand.name,
  url: new URL(withBase("/"), Astro.site).toString(),
  description: brand.description,
  potentialAction: {
    "@type": "SearchAction",
    target: `${new URL(withBase("/search"), Astro.site).toString()}?q={search_term_string}`,
    "query-input": "required name=search_term_string"
  }
};
---

<BaseLayout title={brand.title} description={brand.description} jsonLd={siteJsonLd}>
  <section class="border-b border-slate-200/80 dark:border-slate-800">
    <div class="content-grid py-14 sm:py-20">
      <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_360px] lg:items-end">
        <div>
          <div class="mb-6 flex flex-wrap items-center gap-3">
            <span class="inline-flex h-12 w-12 items-center justify-center rounded-lg bg-slate-950 text-lg font-black text-white dark:bg-white dark:text-slate-950">{brand.shortName}</span>
            <div>
              <p class="text-sm font-semibold uppercase tracking-[0.18em] text-teal-700 dark:text-teal-300">{home.eyebrow}</p>
              <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">{brand.tagline}</p>
            </div>
          </div>
          <h1 class="max-w-4xl text-4xl font-black leading-tight text-slate-950 sm:text-6xl dark:text-white">
            {home.headline}
          </h1>
          <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-600 dark:text-slate-300">
            {home.intro}
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            {home.actions.map((action) => (
              <a class={homeActionClass(action.variant)} href={resolveLink(action.href)}>{action.label}</a>
            ))}
          </div>
          <div class="mt-8 flex flex-wrap items-center gap-3 text-sm">
            {home.socialLinks.map((link) => (
              <a
                class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white px-4 py-2 font-semibold text-slate-700 transition hover:border-teal-400 hover:text-teal-700 dark:border-slate-800 dark:bg-slate-900 dark:text-slate-200 dark:hover:border-teal-500 dark:hover:text-teal-200"
                href={resolveLink(link.href)}
                target={link.external ? "_blank" : undefined}
                rel={link.external ? "noreferrer" : undefined}
              >
                {link.label}
              </a>
            ))}
          </div>
        </div>

        <aside class="surface rounded-lg p-6">
          <p class="text-sm font-semibold text-coral">{home.now.label}</p>
          <h2 class="mt-2 text-2xl font-black text-slate-950 dark:text-white">{home.now.title}</h2>
          <p class="mt-3 leading-7 text-slate-600 dark:text-slate-300">
            {home.now.description}
          </p>
          <dl class="mt-6 grid grid-cols-2 gap-3 text-center">
            <div class="rounded-lg border border-slate-200 p-3 dark:border-slate-800">
              <dt class="text-xs text-slate-500 dark:text-slate-400">文章</dt>
              <dd class="mt-1 text-2xl font-black text-slate-950 dark:text-white">{posts.length}</dd>
            </div>
            <div class="rounded-lg border border-slate-200 p-3 dark:border-slate-800">
              <dt class="text-xs text-slate-500 dark:text-slate-400">标签</dt>
              <dd class="mt-1 text-2xl font-black text-slate-950 dark:text-white">{tagCount}</dd>
            </div>
            <div class="rounded-lg border border-slate-200 p-3 dark:border-slate-800">
              <dt class="text-xs text-slate-500 dark:text-slate-400">总字数</dt>
              <dd class="mt-1 text-2xl font-black text-slate-950 dark:text-white">{numberFormatter.format(totalWords)}</dd>
            </div>
            <div class="rounded-lg border border-slate-200 p-3 dark:border-slate-800">
              <dt class="text-xs text-slate-500 dark:text-slate-400">最近更新</dt>
              <dd class="mt-1 text-sm font-black text-slate-950 dark:text-white">{latestUpdate ? formatDate(latestUpdate) : "暂无"}</dd>
            </div>
          </dl>
        </aside>
      </div>
    </div>
  </section>

  <section class="content-grid py-12">
    <div class="mb-6 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-sm font-semibold text-teal-700 dark:text-teal-300">{home.featured.label}</p>
        <h2 class="mt-1 text-3xl font-black text-slate-950 dark:text-white">{home.featured.title}</h2>
      </div>
      <a class="text-sm font-semibold text-teal-700 hover:text-teal-900 dark:text-teal-300 dark:hover:text-teal-100" href={withBase("/archive")}>{home.featured.linkLabel}</a>
    </div>
    <div class="grid gap-5 md:grid-cols-2">
      {featuredPosts.map((post) => <PostCard post={post} featured />)}
    </div>
  </section>

  <section class="content-grid py-12">
    <div class="mb-6 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-sm font-semibold text-teal-700 dark:text-teal-300">{home.latest.label}</p>
        <h2 class="mt-1 text-3xl font-black text-slate-950 dark:text-white">{home.latest.title}</h2>
      </div>
      <a class="text-sm font-semibold text-teal-700 hover:text-teal-900 dark:text-teal-300 dark:hover:text-teal-100" href={withBase("/blog")}>{home.latest.linkLabel}</a>
    </div>
    <div class="grid gap-5 md:grid-cols-3">
      {latestPosts.map((post) => <PostCard post={post} />)}
    </div>
  </section>

  <section class="content-grid py-12">
    <div class="grid gap-5 lg:grid-cols-[0.85fr_1.15fr] lg:items-stretch">
      <div class="surface rounded-lg p-6">
        <p class="text-sm font-semibold text-coral">{home.projects.label}</p>
        <h2 class="mt-2 text-3xl font-black text-slate-950 dark:text-white">{home.projects.title}</h2>
        <p class="mt-4 leading-7 text-slate-600 dark:text-slate-300">
          {home.projects.description}
        </p>
        <a class="mt-6 inline-flex rounded-full bg-teal-700 px-5 py-3 text-sm font-semibold text-white transition hover:bg-teal-800" href={withBase("/projects")}>{home.projects.actionLabel}</a>
      </div>
      <div class="grid gap-5 sm:grid-cols-3">
        {home.projects.cards.map((card) => (
          <div class="surface rounded-lg p-5">
            <p class="text-sm font-semibold text-teal-700 dark:text-teal-300">{card.label}</p>
            <h3 class="mt-2 font-bold text-slate-950 dark:text-white">{card.title}</h3>
            <p class="mt-3 text-sm leading-6 text-slate-600 dark:text-slate-300">{card.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
