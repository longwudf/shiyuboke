---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { projects } from "@/data/projects";
import { brand } from "@/data/site";
import { withBase } from "@/utils/url";
---

<BaseLayout title={`专题 | ${brand.name}`} description="安全、浏览器、SRE 和 AI 工程专题入口。">
  <section class="content-grid py-12">
    <div class="mb-10 max-w-2xl">
      <h1 class="text-4xl font-black text-slate-950 dark:text-white">专题</h1>
      <p class="mt-4 text-lg leading-8 text-slate-600 dark:text-slate-300">把文章按长期关注的技术主线组织起来，方便从单篇笔记回到完整脉络。</p>
    </div>
    <div class="grid gap-5 md:grid-cols-2">
      {projects.map((project) => (
        <article class="surface rounded-lg p-6">
          <h2 class="text-xl font-bold text-slate-950 dark:text-white">{project.name}</h2>
          <p class="mt-3 text-slate-600 dark:text-slate-300">{project.summary}</p>
          <div class="mt-5 flex flex-wrap gap-2">
            {project.stack.map((item) => <span class="tag-pill">{item}</span>)}
          </div>
          <a class="mt-6 inline-flex text-sm font-semibold text-teal-700 hover:text-teal-900 dark:text-teal-300 dark:hover:text-teal-100" href={withBase(`/projects/${project.slug}`)}>
            查看详情
          </a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
