---
import ThemeToggle from "./ThemeToggle.astro";
import { brand, navItems } from "@/data/site";
import { withBase } from "@/utils/url";

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
const normalizePath = (path: string) => path.replace(/\/$/, "") || "/";
const isActive = (href: string) => {
  const itemPath = normalizePath(withBase(href));
  if (href === "/") return currentPath === itemPath;
  return currentPath === itemPath || currentPath.startsWith(`${itemPath}/`);
};
---

<header class="sticky top-0 z-40 border-b border-slate-200 bg-paper shadow-sm dark:border-slate-800 dark:bg-slate-950">
  <div class="content-grid flex h-16 items-center gap-4">
    <a href={withBase("/")} class="shrink-0 text-base font-bold tracking-normal text-slate-950 dark:text-white" aria-label="返回首页">
      {brand.name}
    </a>
    <nav class="no-scrollbar ml-auto flex min-w-0 items-center gap-1 overflow-x-auto text-sm font-medium text-slate-600 dark:text-slate-300" aria-label="主导航">
      {navItems.map((item) => (
        <a
          class={`shrink-0 rounded-full px-3 py-2 transition hover:bg-white hover:text-teal-700 dark:hover:bg-slate-900 dark:hover:text-teal-200 ${isActive(item.href) ? "bg-white text-teal-700 shadow-sm dark:bg-slate-900 dark:text-teal-200" : ""}`}
          href={withBase(item.href)}
          aria-current={isActive(item.href) ? "page" : undefined}
        >
          {item.label}
        </a>
      ))}
      <ThemeToggle />
    </nav>
  </div>
</header>
