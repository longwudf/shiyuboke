---
import type { BlogPost } from "@/utils/posts";
import { formatDate, getReadingStats } from "@/utils/posts";
import { withBase } from "@/utils/url";
import TagList from "./TagList.astro";

interface Props {
  post: BlogPost;
  featured?: boolean;
  note?: string;
}

const { post, featured = false, note } = Astro.props;
const reading = getReadingStats(post.body);
const postUrl = withBase(`/blog/${post.slug}`);
---

<article class="surface overflow-hidden rounded-lg transition hover:-translate-y-0.5 hover:border-teal-300">
  {post.data.cover && (
    <a href={postUrl} class="group block overflow-hidden">
      <img
        class={`aspect-[16/9] w-full object-cover transition duration-300 group-hover:scale-[1.02] ${featured ? "max-h-72" : "max-h-48"}`}
        src={withBase(post.data.cover)}
        alt={post.data.title}
        loading="lazy"
      />
    </a>
  )}
  <div class={`${featured ? "p-6 sm:p-7" : "p-5"}`}>
    <div class="mb-4 flex flex-wrap items-center gap-2 text-sm text-slate-500 dark:text-slate-400">
      <a class="rounded-full bg-slate-100 px-3 py-1 font-medium text-slate-700 hover:text-teal-700 dark:bg-slate-800 dark:text-slate-200" href={withBase(`/categories/${encodeURIComponent(post.data.category)}`)}>
        {post.data.category}
      </a>
      <span>{formatDate(post.data.date)}</span>
      <span>{reading.label}</span>
    </div>
    {note && <p class="mb-3 text-sm font-semibold text-coral">{note}</p>}
    <a href={postUrl} class="group block">
      <h2 class={`${featured ? "text-2xl" : "text-xl"} font-bold leading-tight text-slate-950 group-hover:text-teal-700 dark:text-white dark:group-hover:text-teal-200`}>
        {post.data.title}
      </h2>
      <p class="mt-3 line-clamp-3 text-slate-600 dark:text-slate-300">{post.data.description}</p>
    </a>
    <div class="mt-5">
      <TagList tags={post.data.tags} />
    </div>
    <div class="mt-5 flex justify-end">
      <button
        type="button"
        class="rounded-full border border-slate-200 px-3 py-1 text-xs font-semibold text-slate-600 transition hover:border-coral hover:text-coral dark:border-slate-700 dark:text-slate-300"
        data-bookmark-url={postUrl}
        aria-pressed="false"
      >
        稍后读
      </button>
    </div>
  </div>
</article>
