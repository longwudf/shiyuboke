---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
  compact?: boolean;
}

const headings = Astro.props.headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
const { compact = false } = Astro.props;
const asideClass = compact ? "" : "article-toc-fixed";
---

{
  headings.length > 0 && (
    <aside class={asideClass}>
      <div class="rounded-lg border border-slate-200 bg-white p-4 text-sm shadow-soft dark:border-slate-800 dark:bg-slate-900">
        <p class="mb-3 font-semibold text-slate-950 dark:text-white">文章目录</p>
        <nav aria-label="文章目录">
          <ul class="space-y-2.5 text-slate-500 dark:text-slate-400">
            {headings.map((heading) => (
              <li class={heading.depth === 3 ? "pl-4" : ""}>
                <a class="block border-l border-transparent pl-3 leading-6 transition hover:border-teal-400 hover:text-teal-700 dark:hover:text-teal-200" href={`#${heading.slug}`} data-toc-link={heading.slug}>{heading.text}</a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </aside>
  )
}
